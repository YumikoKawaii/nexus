KAFKA_BROKERS=
KAFKA_VERSION=3.6.0
KAFKA_CONSUMER_GROUP=nexus
INPUT_TOPICS=otel.traces,otel.metrics,otel.logs
OUTPUT_TOPIC_PREFIX=otel.flat
LOG_LEVEL=info

# Consumer
CONSUMER_OFFSET_RESET=newest              # newest | oldest
CONSUMER_BALANCE_STRATEGY=roundrobin      # roundrobin | range | sticky
CONSUMER_AUTO_COMMIT=true
CONSUMER_AUTO_COMMIT_INTERVAL=1s
CONSUMER_SESSION_TIMEOUT=30s
CONSUMER_HEARTBEAT_INTERVAL=3s
CONSUMER_REBALANCE_TIMEOUT=60s
CONSUMER_FETCH_MIN_BYTES=1
CONSUMER_FETCH_DEFAULT_BYTES=1048576      # 1 MiB
CONSUMER_FETCH_MAX_BYTES=10485760         # 10 MiB

# Pipeline
CHANNEL_BUFFER_SIZE=1000
WORKER_COUNT=4
BATCH_ENABLED=true
BATCH_SIZE=100
BATCH_TIMEOUT=500ms

# Producer
PRODUCER_MODE=async                       # sync | async
PRODUCER_ACKS=local                       # none | local | all
PRODUCER_RETRY_MAX=3
PRODUCER_RETRY_BACKOFF=100ms
PRODUCER_FLUSH_MESSAGES=1000
PRODUCER_FLUSH_BYTES=1048576              # 1 MiB
PRODUCER_FLUSH_FREQUENCY=2s
